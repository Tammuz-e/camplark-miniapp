.my-bookings-page { min-height: 100vh; background: #F9FAFB; }
.my-bookings-topbar {
  display: flex; align-items: center; padding: 24rpx 32rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #F9FAFB; border-bottom: 1rpx solid #F3F4F6;
}
.my-bookings-back { width: 64rpx; height: 64rpx; }
.my-bookings-body { padding: 32rpx 48rpx 180rpx; }

.status-tabs {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
}
.status-tab {
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #6A7282;
  background: #FFF;
  border-radius: 999rpx;
  border: 1rpx solid #F3F4F6;
}
.status-tab.active {
  color: #FFF;
  background: #006045;
  border-color: #006045;
}

.order-list { display: flex; flex-direction: column; gap: 24rpx; }
.order-card {
  background: #FFF;
  border-radius: 32rpx;
  overflow: hidden;
  border: 1rpx solid #F3F4F6;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx rgba(0,0,0,.1);
}
.order-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #F9FAFB;
  border-bottom: 1rpx solid #F3F4F6;
}
.order-no { font-size: 26rpx; color: #6A7282; }
.order-status {
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}
.order-status--pending { color: #D97706; background: #FEF3C7; }
.order-status--checked { color: #059669; background: #D0FAE5; }
.order-status--completed { color: #6A7282; background: #F3F4F6; }

.order-card-body {
  display: flex;
  align-items: stretch;
  padding: 24rpx 28rpx;
}
.order-img {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  border-radius: 16rpx;
  background: #E8D5C4;
}
.order-info {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.order-title { font-size: 32rpx; font-weight: 700; color: #101828; margin-bottom: 8rpx; }
.order-meta { font-size: 24rpx; color: #6A7282; margin-bottom: 4rpx; }
.order-price { font-size: 36rpx; font-weight: 700; color: #009966; }

.order-card-main { display: block; }
.order-card-review {
  padding: 0 28rpx 24rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F3F4F6;
}
.order-review-btn {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 26rpx;
  font-weight: 500;
  color: #006045;
  background: #D0FAE5;
  border-radius: 999rpx;
}
.order-review-block {
  padding: 16rpx 0 0;
}
.order-review-block-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.order-review-block-user { font-size: 26rpx; font-weight: 600; color: #101828; }
.order-review-block-rating { font-size: 24rpx; color: #D97706; }
.order-review-block-date { font-size: 24rpx; color: #9CA3AF; }
.order-review-block-content {
  font-size: 26rpx;
  color: #4A5565;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}
.order-review-block-imgs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.order-review-block-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #F3F4F6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}
.empty-icon {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #F3F4F6;
  margin-bottom: 32rpx;
}
.empty-title { font-size: 36rpx; font-weight: 600; color: #101828; margin-bottom: 16rpx; }
.empty-desc { font-size: 28rpx; color: #6A7282; margin-bottom: 48rpx; }
.empty-btn {
  padding: 24rpx 64rpx;
  background: #009966;
  color: #FFF;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 28rpx;
}
