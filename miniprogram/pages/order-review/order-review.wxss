.order-review-page { min-height: 100vh; background: #F9FAFB; padding-bottom: 180rpx; }
.order-review-spot {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #FFF;
  margin-bottom: 24rpx;
}
.order-review-img {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  background: #E8D5C4;
  flex-shrink: 0;
}
.order-review-info {
  margin-left: 24rpx;
  flex: 1;
  min-width: 0;
}
.order-review-title { font-size: 32rpx; font-weight: 700; color: #101828; display: block; margin-bottom: 8rpx; }
.order-review-date { font-size: 26rpx; color: #6A7282; }

.order-review-form { background: #FFF; padding: 32rpx; }
.order-review-field { margin-bottom: 32rpx; }
.order-review-field:last-child { margin-bottom: 0; }
.order-review-label { font-size: 28rpx; font-weight: 600; color: #101828; display: block; margin-bottom: 16rpx; }

.order-review-stars { display: flex; gap: 16rpx; }
.star { padding: 8rpx; }
.star-icon { width: 48rpx; height: 48rpx; }
.star .star-icon { opacity: 0.3; }
.star.active .star-icon { opacity: 1; }

.order-review-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #101828;
  background: #F9FAFB;
  border-radius: 16rpx;
  box-sizing: border-box;
}
.order-review-count { font-size: 24rpx; color: #9CA3AF; margin-top: 8rpx; display: block; }

.order-review-imgs { display: flex; flex-wrap: wrap; gap: 16rpx; }
.order-review-img-item { position: relative; width: 160rpx; height: 160rpx; }
.img-preview { width: 100%; height: 100%; border-radius: 12rpx; background: #F3F4F6; }
.img-delete {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 28rpx;
  color: #FFF;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
}
.order-review-add-img {
  width: 160rpx;
  height: 160rpx;
  border: 2rpx dashed #D1D5DB;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.add-icon { font-size: 48rpx; color: #9CA3AF; }
.add-text { font-size: 24rpx; color: #9CA3AF; }

.order-review-footer {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #FFF;
  border-top: 1rpx solid #F3F4F6;
}
.order-review-submit {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFF;
  background: #006045;
  border-radius: 24rpx;
  border: none;
}
