/* Figma 首页 100% - 376px 设计稿, 设计稿 328px 内容区 */
.index-page { min-height: 100vh; background: #FFF; }
.index-body { padding: 64rpx 48rpx 180rpx; background: #F9FAFB; }

.hero { margin-bottom: 16rpx; padding-left: 0; }
.hero-title-wrap { display: flex; flex-direction: column; padding-left: 0; }
.hero-title { font-size: 72rpx; font-weight: 800; color: #101828; line-height: 1.11; text-align: left; }
.hero-accent { color: #009966; }
.hero-desc { display: block; font-size: 36rpx; font-weight: 400; color: #6A7282; margin-top: 8rpx; line-height: 1.56; text-align: left; padding-left: 0; }

.search-bar {
  display: flex; align-items: center; height: 114rpx; padding: 0 24rpx;
  background: #FFF; border: 1rpx solid #F3F4F6; border-radius: 32rpx;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx rgba(0,0,0,.1);
  margin-bottom: 32rpx;
}
.search-icon-left { width: 56rpx; display: flex; align-items: center; justify-content: center; }
.search-inner { flex: 1; }
.search-icon-wrap { width: 88rpx; display: flex; align-items: center; justify-content: center; }
.search-placeholder { font-size: 28rpx; color: rgba(16,24,40,.5); }
.search-icon { width: 85rpx; height: 85rpx; }
.filter-icon { width: 85rpx; height: 85rpx; }

.section-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 48rpx; }
.section-title { font-size: 40rpx; font-weight: 700; color: #101828; }
.section-more { font-size: 28rpx; font-weight: 600; color: #009966; }

.hot-swiper { height: 680rpx; margin: 0 -48rpx; }
.swiper-item-wrap { padding: 0 48rpx; height: 100%; }
.home-card--swiper { height: 100%; display: flex; flex-direction: column; }
.home-card--swiper .home-card-img-wrap { flex: 1; min-height: 360rpx; }
.home-card--swiper .home-card-info { flex-shrink: 0; }
.card-list { display: flex; flex-direction: column; gap: 48rpx; }
.home-card {
  width: 100%; background: #FFF; border-radius: 40rpx;
  overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.08);
}
.home-card-img-wrap {
  position: relative; width: 100%; height: 490rpx;
  border-radius: 40rpx 40rpx 0 0; overflow: hidden;
}
.home-card-img { width: 100%; height: 100%; background: #E8D5C4; display: block; }
.home-card-fav {
  position: absolute; right: 24rpx; top: 24rpx;
  display: flex; align-items: center; justify-content: center;
}
.home-card-fav image { width: 80rpx; height: 80rpx; }
.home-card-badge {
  position: absolute; right: 24rpx; bottom: 24rpx;
  display: flex; align-items: center; gap: 6rpx;
  padding: 8rpx 14rpx; border-radius: 999rpx;
  background: rgba(243,244,246,0.95); font-size: 24rpx; font-weight: 600; color: #101828;
}
.home-card-badge .badge-icon { width: 24rpx; height: 24rpx; }
.home-card-info { padding: 32rpx; }
.home-card-name { font-size: 36rpx; font-weight: 700; color: #101828; display: block; margin-bottom: 12rpx; line-height: 1.4; }
.home-card-meta { font-size: 26rpx; color: #6A7282; display: flex; align-items: center; gap: 8rpx; margin-bottom: 20rpx; }
.meta-icon { width: 28rpx; height: 28rpx; opacity: .8; }
.home-card-footer { display: flex; justify-content: space-between; align-items: center; }
.home-card-price-wrap { display: flex; align-items: baseline; gap: 4rpx; }
.home-card-price { font-size: 40rpx; font-weight: 700; color: #009966; }
.home-card-unit { font-size: 28rpx; font-weight: 400; color: #6A7282; }
.home-card-btn { padding: 18rpx 32rpx; background: #101828; color: #FFF; font-size: 28rpx; font-weight: 500; border-radius: 24rpx; }

.nearby-section { margin-top: 48rpx; }
.nearby-card-list { display: flex; flex-direction: column; gap: 32rpx; }
.nearby-card {
  position: relative; display: flex; align-items: stretch;
  height: 242rpx; background: #FFF; border-radius: 32rpx; border: 1rpx solid #F3F4F6;
  overflow: hidden; box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx rgba(0,0,0,.1);
}
.nearby-card-img-wrap { position: relative; width: 192rpx; height: 192rpx; flex-shrink: 0; margin: 25rpx; border-radius: 24rpx; overflow: hidden; }
.nearby-card-badge {
  position: absolute; right: 12rpx; bottom: 12rpx;
  display: flex; align-items: center; gap: 6rpx;
  padding: 6rpx 12rpx; border-radius: 999rpx;
  background: rgba(243,244,246,0.95); font-size: 24rpx; font-weight: 600; color: #101828;
}
.nearby-card-badge .badge-icon { width: 24rpx; height: 24rpx; }
.nearby-card-img { width: 100%; height: 100%; background: #E8D5C4; }
.nearby-card-info { flex: 1; padding: 25rpx 25rpx 25rpx 0; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.nearby-card-name { font-size: 32rpx; font-weight: 700; color: #101828; margin-bottom: 8rpx; }
.nearby-card-meta { font-size: 24rpx; color: #6A7282; display: flex; align-items: center; gap: 8rpx; margin-bottom: 12rpx; }
.nearby-card-footer { display: flex; justify-content: space-between; align-items: center; }
.nearby-card-price { font-size: 36rpx; font-weight: 700; color: #009966; }
.nearby-card-btn { padding: 12rpx 24rpx; background: #101828; color: #FFF; font-size: 24rpx; font-weight: 500; border-radius: 20rpx; }
.nearby-card-rating {
  display: inline-flex; align-items: center; gap: 6rpx;
  padding: 6rpx 12rpx; border-radius: 999rpx;
  background: #F3F4F6; font-size: 24rpx; font-weight: 600; color: #101828;
}
.nearby-card-rating .badge-icon { width: 24rpx; height: 24rpx; }
.nearby-card-fav { position: absolute; right: 25rpx; top: 25rpx; display: flex; align-items: center; justify-content: center; }
.nearby-card-fav .fav-icon { width: 80rpx; height: 80rpx; }

.club-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 12rpx; }
.club-tag { font-size: 22rpx; padding: 4rpx 12rpx; background: #E8F5E9; color: #009966; border-radius: 8rpx; }

/* 搜索浮层 */
.search-overlay {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 200;
}
.search-overlay-mask {
  position: absolute; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,.4);
}
.search-overlay-content {
  position: absolute; left: 0; right: 0; top: 0;
  padding-top: env(safe-area-inset-top);
  background: #FFF; max-height: 80vh;
  display: flex; flex-direction: column;
}
.search-overlay-header {
  display: flex; align-items: center; gap: 24rpx;
  padding: 24rpx 32rpx; border-bottom: 1rpx solid #F3F4F6;
}
.search-overlay-input-wrap {
  flex: 1; display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 24rpx; background: #F9FAFB;
  border-radius: 24rpx;
}
.search-overlay-icon { width: 40rpx; height: 40rpx; opacity: .6; }
.search-overlay-input { flex: 1; font-size: 30rpx; }
.search-overlay-clear { font-size: 40rpx; color: #9CA3AF; padding: 0 8rpx; }
.search-overlay-cancel { font-size: 30rpx; color: #009966; font-weight: 500; }
.search-overlay-body { flex: 1; overflow-y: auto; padding: 24rpx 32rpx 48rpx; }
.search-empty {
  padding: 80rpx 0; text-align: center; font-size: 28rpx; color: #9CA3AF;
}
.search-group { margin-bottom: 32rpx; }
.search-group-title {
  font-size: 24rpx; font-weight: 700; color: #6A7282;
  text-transform: uppercase; margin-bottom: 16rpx; display: block;
}
.search-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 24rpx 0; border-bottom: 1rpx solid #F3F4F6;
}
.search-item-img {
  width: 96rpx; height: 96rpx; border-radius: 16rpx;
  flex-shrink: 0; background: #E5E7EB;
}
.search-item-info { flex: 1; min-width: 0; }
.search-item-name { font-size: 30rpx; font-weight: 600; color: #101828; display: block; }
.search-item-meta { font-size: 24rpx; color: #6A7282; display: block; margin-top: 4rpx; }

