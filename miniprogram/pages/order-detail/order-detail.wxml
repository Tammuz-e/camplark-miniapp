<view class="order-detail-page" wx:if="{{order}}">
  <view class="order-detail-topbar">
    <image class="order-detail-back" src="/images/icons/back.svg" mode="aspectFit" bindtap="onBack" />
  </view>
  <view class="order-detail-body">
    <view class="order-detail-header">
      <view class="order-detail-status order-detail-status--{{statusClass}}">{{order.status}}</view>
      <text class="order-detail-no">订单号 {{order.orderNo}}</text>
    </view>

    <view class="order-detail-spot" bindtap="onSpotTap">
      <image class="order-detail-img" src="{{order.img}}" mode="aspectFill" />
      <view class="order-detail-spot-info">
        <text class="order-detail-title">{{order.campName}} · {{order.spotName}}</text>
        <view class="order-detail-meta">
          <text>{{order.checkIn}} 至 {{order.checkOut}}</text>
        </view>
        <view class="order-detail-meta">
          <text>{{order.nights}}天 · {{order.guests}}人</text>
        </view>
        <text class="order-detail-price">¥{{order.totalPrice}}</text>
      </view>
      <text class="order-detail-arrow">›</text>
    </view>

    <view class="order-detail-section">
      <text class="order-detail-section-title">预订信息</text>
      <view class="order-detail-row">
        <text class="order-detail-label">入住日期</text>
        <text class="order-detail-value">{{order.checkIn}}</text>
      </view>
      <view class="order-detail-row">
        <text class="order-detail-label">退房日期</text>
        <text class="order-detail-value">{{order.checkOut}}</text>
      </view>
      <view class="order-detail-row">
        <text class="order-detail-label">入住天数</text>
        <text class="order-detail-value">{{order.nights}}晚</text>
      </view>
      <view class="order-detail-row">
        <text class="order-detail-label">入住人数</text>
        <text class="order-detail-value">{{order.guests}}人</text>
      </view>
    </view>

    <view class="order-detail-section">
      <text class="order-detail-section-title">费用明细</text>
      <view class="order-detail-total-row">
        <text class="order-detail-total-label">合计</text>
        <text class="order-detail-total-value">¥{{order.totalPrice}}</text>
      </view>
    </view>

    <view class="order-detail-review" wx:if="{{order.status === '已完成'}}">
      <view class="order-detail-review-btn" wx:if="{{!review}}" bindtap="onReviewTap">去评价</view>
      <view class="order-detail-review-block" wx:else>
        <view class="order-detail-review-header">
          <text class="order-detail-review-user">{{review.userName}}</text>
          <text class="order-detail-review-rating">{{review.rating}}分</text>
          <text class="order-detail-review-date">{{review.date}}</text>
        </view>
        <text class="order-detail-review-content">{{review.content}}</text>
        <view class="order-detail-review-imgs" wx:if="{{review.imgs && review.imgs.length}}">
          <image class="order-detail-review-img" src="{{img}}" mode="aspectFill" wx:for="{{review.imgs}}" wx:key="*this" wx:for-item="img" />
        </view>
      </view>
    </view>
  </view>
</view>
