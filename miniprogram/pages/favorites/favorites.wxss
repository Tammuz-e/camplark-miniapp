/* Figma 收藏页 100% - 卡片 328x121 图96x96 */
.favorites-page { min-height: 100vh; background: #FFF; }
.favorites-header {
  display: flex; align-items: center; padding: 24rpx 32rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
  background: #FFF; border-bottom: 1rpx solid #F3F4F6;
}
.favorites-back { width: 64rpx; height: 64rpx; }
.favorites-body { padding: 48rpx 48rpx 180rpx; background: #F9FAFB; }

.page-title { display: block; font-size: 48rpx; font-weight: 700; color: #101828; margin-bottom: 48rpx; }

.fav-section { margin-bottom: 48rpx; }
.fav-section-title { display: block; font-size: 32rpx; font-weight: 600; color: #6A7282; margin-bottom: 24rpx; padding-left: 4rpx; }
.favorites-content { display: flex; flex-direction: column; }
.fav-section .fav-card { margin-bottom: 32rpx; }
.fav-section .fav-card:last-child { margin-bottom: 0; }
.club-tags { display: flex; flex-wrap: wrap; gap: 8rpx; margin-bottom: 8rpx; }
.club-tag { font-size: 22rpx; padding: 4rpx 12rpx; background: #E8F5E9; color: #009966; border-radius: 8rpx; }
.fav-card {
  position: relative; display: flex; align-items: stretch; height: 242rpx;
  background: #FFF; border-radius: 32rpx; border: 1rpx solid #F3F4F6;
  overflow: hidden; box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx rgba(0,0,0,.1);
}
.fav-card-img-wrap { width: 192rpx; height: 192rpx; flex-shrink: 0; margin: 25rpx; border-radius: 24rpx; overflow: hidden; }
.fav-card-img { width: 100%; height: 100%; background: #E8D5C4; }
.fav-card-info { flex: 1; padding: 25rpx 25rpx 25rpx 0; display: flex; flex-direction: column; justify-content: space-between; min-width: 0; }
.fav-card-name { font-size: 32rpx; font-weight: 700; color: #101828; }
.fav-card-meta { font-size: 24rpx; color: #6A7282; display: flex; align-items: center; gap: 8rpx; }
.fav-card-price { font-size: 36rpx; font-weight: 700; color: #009966; }
.fav-card-heart { position: absolute; right: 25rpx; top: 25rpx; display: flex; align-items: center; justify-content: center; }
.fav-card-heart image { width: 80rpx; height: 80rpx; }
.icon-12 { width: 32rpx; height: 32rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 48rpx; }
.empty-icon { width: 160rpx; height: 160rpx; border-radius: 50%; background: #F3F4F6; margin-bottom: 32rpx; }
.empty-title { font-size: 36rpx; font-weight: 600; color: #101828; margin-bottom: 16rpx; }
.empty-desc { font-size: 28rpx; color: #6A7282; margin-bottom: 48rpx; }
.empty-btn { padding: 24rpx 64rpx; background: #009966; color: #FFF; font-size: 30rpx; font-weight: 500; border-radius: 28rpx; }
