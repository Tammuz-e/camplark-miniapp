/* 俱乐部页 */
.club-page { min-height: 100vh; background: #F9FAFB; }
.club-body { padding: 48rpx 48rpx 180rpx; }

.club-hero {
  margin-bottom: 48rpx; padding-bottom: 32rpx;
  border-bottom: 1rpx solid #F3F4F6;
}
.club-hero-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.page-title { font-size: 48rpx; font-weight: 700; color: #101828; }
.club-create-btn {
  padding: 16rpx 28rpx; font-size: 26rpx; font-weight: 500;
  background: #009966; color: #FFF; border-radius: 24rpx;
}
.page-desc { display: block; font-size: 28rpx; color: #6A7282; }

.club-section { margin-bottom: 40rpx; }
.club-section-title {
  display: block; font-size: 34rpx; font-weight: 700; color: #101828;
  margin-bottom: 24rpx; padding-left: 4rpx;
}

.club-list { display: flex; flex-direction: column; gap: 32rpx; }
.club-card-wrap { display: block; text-decoration: none; color: inherit; }
.club-card-hover { opacity: 0.9; }
.club-card {
  display: flex; align-items: stretch;
  min-height: 242rpx; background: #FFF; border-radius: 32rpx;
  border: 1rpx solid #F3F4F6; overflow: hidden;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx rgba(0,0,0,.1);
}
.club-card-img-wrap {
  width: 192rpx; height: 192rpx; flex-shrink: 0; margin: 25rpx; margin-right: 0;
  border-radius: 24rpx; overflow: hidden;
}
.club-card-img { width: 100%; height: 100%; background: #E8D5C4; }
.club-card-info {
  flex: 1; padding: 25rpx 25rpx 25rpx 25rpx; min-width: 0;
  display: flex; flex-direction: column; justify-content: space-between;
}
.club-card-name { font-size: 32rpx; font-weight: 700; color: #101828; margin-bottom: 8rpx; display: block; }
.club-card-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 12rpx; margin-bottom: 8rpx; }
.club-card-members { font-size: 24rpx; color: #6A7282; }
.club-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.club-tag { font-size: 22rpx; padding: 4rpx 12rpx; background: #E8F5E9; color: #009966; border-radius: 8rpx; }
.club-card-desc {
  font-size: 24rpx; color: #6A7282; line-height: 1.45;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  margin-bottom: 12rpx;
}
.club-card-footer { display: flex; justify-content: space-between; align-items: center; }
.club-card-price { font-size: 36rpx; font-weight: 700; color: #009966; }
.club-enter-btn {
  padding: 16rpx 28rpx; font-size: 26rpx; font-weight: 500;
  background: #101828; color: #FFF; border-radius: 24rpx;
  margin-left: auto;
}
.club-join-btn {
  padding: 16rpx 28rpx; font-size: 26rpx; font-weight: 500;
  background: #009966; color: #FFF; border-radius: 24rpx;
}
