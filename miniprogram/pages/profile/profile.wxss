/* Figma 1-417 我的页 100% - 394px 设计稿 */
.profile-page { min-height: 100vh; background: #FFF; }
.profile-body {
  padding: 64rpx 48rpx 180rpx 48rpx; background: #F9FAFB; min-height: 100vh; box-sizing: border-box;
  display: flex; flex-direction: column; gap: 64rpx;
}
.profile-copyright {
  margin-top: auto;
  padding: 48rpx 0 24rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  text-align: center;
}

.user-section {
  display: flex; flex-direction: column; align-items: center; gap: 32rpx;
}
.avatar-box {
  width: 192rpx; height: 192rpx; border-radius: 50%;
  background: #E5E7EB; border: 7rpx solid #FFF;
  box-shadow: 0 8rpx 12rpx -8rpx rgba(0,0,0,.1), 0 20rpx 30rpx -6rpx rgba(0,0,0,.1);
  overflow: hidden;
}
.avatar { width: 100%; height: 100%; }
.avatar-default { background: #E5E7EB; }
.user-name { font-size: 48rpx; font-weight: 700; color: #101828; line-height: 1.33; text-align: center; }
.user-name-login { color: #009966; }
.user-tag { font-size: 32rpx; font-weight: 400; color: #6A7282; line-height: 1.5; text-align: center; }

.stats-bar {
  display: flex; align-items: stretch; justify-content: stretch;
  width: 100%; height: 170rpx; background: #FFF; border-radius: 32rpx;
  border: 1rpx solid #F3F4F6;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx 0 rgba(0,0,0,.1);
}
.stat { display: flex; flex-direction: column; align-items: center; justify-content: center; flex: 1; }
.stat-tap { cursor: pointer; }
.stat-value { font-size: 40rpx; font-weight: 700; color: #101828; line-height: 1.4; }
.stat-name { font-size: 24rpx; font-weight: 400; color: #6A7282; line-height: 1.33; margin-top: 4rpx; }
.stat-line { width: 1rpx; align-self: stretch; background: #F3F4F6; margin: 16rpx 0; }

.menu-group { display: flex; flex-direction: column; gap: 16rpx; width: 100%; }
.menu-row {
  display: flex; align-items: center; height: 138rpx;
  padding: 0 32rpx; background: #FFF; border-radius: 32rpx; gap: 32rpx;
  border: 1rpx solid #F3F4F6;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx 0 rgba(0,0,0,.1);
}
.menu-row text { font-size: 32rpx; font-weight: 500; color: #101828; line-height: 1.5; }
.menu-row-btn {
  width: 100%; padding: 0 32rpx; margin: 0; 
  background: #FFF; border: 1rpx solid #F3F4F6;
  border-radius: 32rpx; text-align: left;
  display: flex; align-items: center; height: 138rpx; gap: 32rpx;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx 0 rgba(0,0,0,.1);
}
.menu-row-btn text { font-size: 32rpx; font-weight: 500; color: #101828; line-height: 1.5; }
.menu-row-btn::after { border: none; }
.icon-box {
  width: 80rpx; height: 80rpx; min-width: 80rpx; min-height: 80rpx;
  border-radius: 40rpx; overflow: hidden;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; box-sizing: border-box;
}
.icon-box image { width: 52rpx; height: 52rpx; }
.icon-box .icon-img-sm { width: 35rpx; height: 35rpx; }
.icon-box--green { background: #D0FAE5; }
.icon-box--pink { background: #FFE2E2; }
.icon-box--gray { background: #F3F4F6; }

.login-modal-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
}
.login-modal {
  position: fixed; left: 0; right: 0; top: 50%;
  transform: translateY(-50%) scale(0.9);
  opacity: 0;
  z-index: 101;
  transition: all 0.3s;
}
.login-modal-show { transform: translateY(-50%) scale(1); opacity: 1; }
.login-modal-content {
  margin: 0 48rpx;
  min-height: 520rpx;
  background: #FFF;
  border-radius: 32rpx;
  overflow: hidden;
}
.login-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 40rpx 32rpx;
}
.login-modal-title { font-size: 40rpx; font-weight: 700; color: #101828; }
.login-modal-close { font-size: 48rpx; color: #9CA3AF; padding: 8rpx; }
.login-modal-body { padding: 0 40rpx 40rpx; }
.login-modal-avatar-wrap { margin-bottom: 40rpx; }
.login-modal-nickname-wrap { }
.login-modal-label { font-size: 28rpx; color: #6A7282; display: block; margin-bottom: 16rpx; }
.login-avatar-btn {
  display: flex; align-items: center; justify-content: center;
  width: 200rpx; height: 200rpx;
  border: 2rpx dashed #D1D5DB; border-radius: 50%;
  background: #F9FAFB;
  padding: 0; margin: 0;
}
.login-avatar-btn::after { border: none; }
.login-avatar-preview { width: 100%; height: 100%; border-radius: 50%; }
.login-avatar-placeholder { font-size: 28rpx; color: #9CA3AF; }
.login-nickname-input {
  width: 100%; padding: 36rpx 28rpx;
  min-height: 96rpx;
  font-size: 28rpx; color: #101828;
  background: #F9FAFB; border-radius: 16rpx;
  box-sizing: border-box;
}
.login-modal-footer { padding: 0 40rpx 48rpx; }
.login-modal-submit {
  width: 100%; height: 88rpx; line-height: 88rpx;
  font-size: 32rpx; font-weight: 600; color: #FFF;
  background: #006045; border-radius: 24rpx; border: none;
}
