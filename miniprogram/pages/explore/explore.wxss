/* Figma 探索页 100% - 卡片 328x121 图96x96 左 */
.explore-page { min-height: 100vh; background: #FFF; }
.explore-body { padding: 48rpx 48rpx 180rpx; background: #F9FAFB; }

.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40rpx; }
.page-title { font-size: 48rpx; font-weight: 700; color: #101828; }
.view-toggle {
  display: flex; background: #F3F4F6; border-radius: 28rpx; padding: 8rpx;
}
.toggle-btn { padding: 12rpx 24rpx; border-radius: 20rpx; font-size: 28rpx; font-weight: 500; color: #6A7282; }
.toggle-btn--active { background: #FFF; color: #101828; box-shadow: 0 2rpx 8rpx rgba(0,0,0,.06); }

.search-bar {
  display: flex; align-items: center; height: 114rpx; padding: 0 24rpx;
  background: #FFF; border: 1rpx solid #F3F4F6; border-radius: 32rpx;
  box-shadow: 0 2rpx 4rpx -2rpx rgba(0,0,0,.1), 0 2rpx 6rpx rgba(0,0,0,.1);
  margin-bottom: 32rpx;
}
.search-icon-left { width: 56rpx; display: flex; align-items: center; justify-content: center; }
.search-inner { flex: 1; }
.search-placeholder { font-size: 28rpx; color: rgba(16,24,40,.5); }
.search-icon-wrap { width: 88rpx; display: flex; align-items: center; justify-content: center; }
.search-icon { width: 85rpx; height: 85rpx; }
.filter-icon { width: 85rpx; height: 85rpx; }

.filter-mask {
  position: fixed; left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,.4); z-index: 100;
}
.filter-popup {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #FFF; border-radius: 32rpx 32rpx 0 0;
  z-index: 101; transform: translateY(100%); transition: transform 0.25s ease;
  max-height: 80vh;
  display: flex; flex-direction: column; overflow: hidden;
}
.filter-popup--show { transform: translateY(0); }
.filter-popup-body {
  flex: 1; min-height: 0;
  padding: 48rpx 48rpx 32rpx;
  overflow-y: auto;
}
.filter-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.filter-title { font-size: 36rpx; font-weight: 700; color: #101828; }
.filter-close { width: 64rpx; height: 64rpx; font-size: 48rpx; color: #6A7282; text-align: center; line-height: 64rpx; }
.filter-accom-list { display: flex; flex-direction: column; gap: 24rpx; margin-bottom: 32rpx; }
.filter-guest-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 32rpx; background: #FFF; border: 2rpx solid #E5E7EB; border-radius: 32rpx;
}
.filter-guest-label { font-size: 32rpx; font-weight: 500; color: #101828; }
.filter-guest-stepper { display: flex; align-items: center; gap: 24rpx; }
.filter-guest-btn { width: 56rpx; height: 56rpx; border: 2rpx solid #E5E7EB; border-radius: 16rpx; font-size: 36rpx; color: #101828; text-align: center; line-height: 52rpx; }
.filter-guest-value { font-size: 32rpx; font-weight: 700; color: #101828; min-width: 48rpx; text-align: center; }
.filter-accom-item {
  display: flex; align-items: center; gap: 32rpx;
  padding-left: 32rpx; height: 120rpx;
  background: #FFF; border: 2rpx solid #E5E7EB;
  border-radius: 32rpx;
}
.filter-accom-item--active {
  background: rgba(0,153,102,.1);
  border: 2rpx solid #009966;
  box-shadow: 0 0 0 2rpx rgba(0,153,102,.2);
}
.filter-accom-icon { width: 80rpx; height: 80rpx; flex-shrink: 0; display: block; }
.filter-accom-info { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.filter-accom-title { font-size: 32rpx; font-weight: 700; color: #101828; }
.filter-accom-desc { font-size: 24rpx; font-weight: 500; color: #6A7282; }
.filter-divider { height: 2rpx; background: #F3F4F6; margin-bottom: 32rpx; }
.filter-section { margin-bottom: 32rpx; }
.filter-section-title { font-size: 36rpx; font-weight: 700; color: #101828; display: block; margin-bottom: 24rpx; }

/* 露营者最爱 - Figma 16px border-radius, #E5E7EB border */
.filter-fav-list { display: flex; flex-direction: column; gap: 24rpx; }
.filter-fav-list--row { flex-direction: row; }
.filter-fav-item {
  display: flex; flex-direction: column; gap: 8rpx;
  padding: 32rpx; background: #FFF;
  border: 2rpx solid #E5E7EB; border-radius: 32rpx;
}
.filter-fav-item--active {
  background: rgba(0,153,102,.1);
  border: 2rpx solid #009966;
  box-shadow: 0 0 0 2rpx rgba(0,153,102,.2);
}
.filter-fav-item--active .filter-fav-title { color: #009966; }
.filter-fav-title { font-size: 32rpx; font-weight: 700; color: #101828; }
.filter-fav-desc { font-size: 24rpx; font-weight: 400; color: #6A7282; line-height: 1.5; }

/* 价格区间 - 双滑块单条线 */
.filter-price-wrap { padding: 0 8rpx; }
.range-slider { height: 80rpx; margin-bottom: 16rpx; }
.range-track-inner { position: relative; height: 100%; }
.range-track-bg { position: absolute; left: 0; right: 0; top: 50%; transform: translateY(-50%); height: 8rpx; background: #F3F4F6; border-radius: 999rpx; }
.range-track-fill { position: absolute; left: 0; top: 50%; transform: translateY(-50%); height: 8rpx; background: #101828; border-radius: 999rpx; }
.range-handle { position: absolute; width: 40rpx; height: 40rpx; top: 50%; transform: translate(-50%, -50%); background: #FFF; border: 4rpx solid #101828; border-radius: 50%; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.15); }
.filter-price-labels { display: flex; justify-content: space-between; font-size: 28rpx; font-weight: 500; color: #101828; }

.filter-amenity-grid {
  display: flex; flex-wrap: wrap; gap: 24rpx 32rpx;
}
.filter-amenity-list { display: flex; flex-direction: column; gap: 32rpx; }
.filter-amenity-item {
  display: flex; align-items: center; gap: 24rpx;
  padding: 0;
}
/* Figma: checkbox 20×20px, border #D1D5DC, borderRadius 4px */
.filter-amenity-check {
  width: 40rpx; height: 40rpx; border-radius: 8rpx;
  background: #FFF; border: 2rpx solid #D1D5DC;
  flex-shrink: 0; position: relative; display: flex; align-items: center; justify-content: center;
}
.filter-amenity-item--active .filter-amenity-check {
  background: rgba(0,153,102,.15);
  border: 2rpx solid #009966;
}
.filter-amenity-item--active .filter-amenity-check::after {
  content: ''; position: absolute;
  width: 14rpx; height: 22rpx;
  border: 4rpx solid #009966; border-top: none; border-left: none;
  transform: rotate(45deg); margin-top: -10rpx;
}
.filter-amenity-item--active .filter-amenity-text { color: #009966; font-weight: 600; }
.filter-amenity-text { font-size: 32rpx; font-weight: 500; color: #364153; }
.filter-footer {
  flex-shrink: 0;
  display: flex; justify-content: space-between; align-items: center;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #FFF; border-top: 2rpx solid #F3F4F6;
}
.filter-btn--reset {
  font-size: 28rpx; font-weight: 700; color: #101828;
  padding: 0; background: transparent; border: none;
}
.filter-btn--confirm {
  width: 324rpx; height: 96rpx;
  display: flex; align-items: center; justify-content: center;
  background: #1E2939; color: #FFF;
  font-size: 32rpx; font-weight: 500;
  border-radius: 28rpx;
  box-shadow: 0 8rpx 12rpx -8rpx rgba(0,0,0,.1), 0 20rpx 30rpx -6rpx rgba(0,0,0,.1);
}

.explore-page--map { padding: 0; }
.explore-map-wrap--fullscreen {
  position: fixed; top: 0; left: 0; right: 0; bottom: 151rpx;
  z-index: 10; background: #FFF;
}
.explore-map-wrap--fullscreen .explore-map { width: 100%; height: 100%; }
.map-overlay {
  position: absolute; top: 0; left: 0; right: 0; padding: 48rpx 48rpx 32rpx;
  background: linear-gradient(to bottom, rgba(255,255,255,.95) 0%, transparent 100%);
}
.map-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.map-header .page-title { font-size: 48rpx; font-weight: 700; color: #101828; }
.map-hint { display: block; font-size: 24rpx; color: #6A7282; padding-left: 4rpx; }
.map-locate-btn {
  position: absolute; right: 32rpx; bottom: 32rpx;
  display: flex; align-items: center; gap: 8rpx;
  padding: 16rpx 24rpx; background: #FFF; border-radius: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.1); font-size: 26rpx; color: #101828;
}
.map-locate-btn .locate-icon { width: 32rpx; height: 32rpx; }

.map-camp-panel {
  position: absolute; left: 0; right: 0; bottom: 0; top: 0;
  background: rgba(0,0,0,.4); display: flex; align-items: flex-end; justify-content: center;
  padding: 0 48rpx 120rpx; z-index: 20;
}
.map-camp-card {
  width: 100%; background: #FFF; border-radius: 32rpx;
  padding: 32rpx; box-shadow: 0 -4rpx 24rpx rgba(0,0,0,.12); position: relative;
}
.map-camp-close {
  position: absolute; right: 24rpx; top: 24rpx; width: 64rpx; height: 64rpx;
  font-size: 44rpx; color: #6A7282; text-align: center; line-height: 64rpx;
  z-index: 1; display: flex; align-items: center; justify-content: center;
}
.map-camp-content { display: flex; gap: 24rpx; }
.map-camp-img-wrap { position: relative; flex-shrink: 0; }
.map-camp-img-wrap .home-card-type-tag { left: 8rpx; top: 8rpx; padding: 4rpx 10rpx; font-size: 20rpx; }
.map-camp-img { width: 160rpx; height: 160rpx; border-radius: 50%; flex-shrink: 0; background: #E8D5C4; overflow: hidden; display: block; }
.map-camp-info { flex: 1; min-width: 0; }
.map-camp-name { font-size: 36rpx; font-weight: 700; color: #101828; display: block; margin-bottom: 12rpx; }
.map-camp-meta { font-size: 26rpx; color: #6A7282; display: flex; align-items: center; gap: 8rpx; margin-bottom: 16rpx; }
.map-camp-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.map-camp-price { font-size: 36rpx; font-weight: 700; color: #009966; }
.map-camp-rating {
  display: inline-flex; align-items: center; gap: 6rpx;
  padding: 6rpx 12rpx; border-radius: 999rpx;
  background: #F3F4F6; font-size: 24rpx; font-weight: 600; color: #101828;
}
.map-camp-rating .badge-icon { width: 24rpx; height: 24rpx; }
.map-camp-btn { padding: 24rpx; background: #101828; color: #FFF; font-size: 30rpx; font-weight: 500; border-radius: 24rpx; text-align: center; }
.category-scroll { margin-bottom: 48rpx; white-space: nowrap; }
.cat-pill {
  display: inline-block; padding: 18rpx 30rpx; margin-right: 16rpx; border-radius: 999rpx;
  font-size: 28rpx; font-weight: 500; background: #FFF; border: 1rpx solid #E5E7EB; color: #6A7282;
}
.cat-pill--active { background: #101828; border-color: #101828; color: #FFF; }

/* 与首页轮播图一致的卡片样式，竖列展示 */
.explore-card-list { display: flex; flex-direction: column; gap: 48rpx; }
.explore-card-wrap { width: 100%; }
.home-card {
  width: 100%; background: #FFF; border-radius: 40rpx;
  overflow: hidden; box-shadow: 0 4rpx 12rpx rgba(0,0,0,.08);
}
.home-card--vertical { display: flex; flex-direction: column; }
.home-card--vertical .home-card-img-wrap { flex: none; height: 490rpx; }
.home-card--vertical .home-card-info { flex-shrink: 0; }
.home-card-img-wrap {
  position: relative; width: 100%; height: 490rpx;
  border-radius: 40rpx 40rpx 0 0; overflow: hidden;
}
.home-card-type-tag {
  position: absolute; left: 24rpx; top: 24rpx; z-index: 5;
  padding: 6rpx 16rpx; border-radius: 8rpx;
  font-size: 24rpx; font-weight: 600; color: #FFF;
  background: rgba(0,0,0,.45);
}
.home-card-img-swiper { width: 100%; height: 100%; }
.home-card-img { width: 100%; height: 100%; background: #E8D5C4; display: block; }
.home-card-fav {
  position: absolute; right: 24rpx; top: 24rpx;
  display: flex; align-items: center; justify-content: center;
}
.home-card-fav image { width: 80rpx; height: 80rpx; }
.home-card-badge {
  position: absolute; right: 24rpx; bottom: 24rpx;
  display: flex; align-items: center; gap: 6rpx;
  padding: 8rpx 14rpx; border-radius: 999rpx;
  background: rgba(243,244,246,0.95); font-size: 24rpx; font-weight: 600; color: #101828;
}
.home-card-badge .badge-icon { width: 24rpx; height: 24rpx; }
.home-card-info { padding: 32rpx; }
.home-card-name { font-size: 36rpx; font-weight: 700; color: #101828; display: block; margin-bottom: 12rpx; line-height: 1.4; }
.home-card-subtitle { font-size: 26rpx; color: #6A7282; display: block; margin-bottom: 8rpx; }
.home-card-meta { font-size: 26rpx; color: #6A7282; display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 20rpx; }
.home-card-meta .meta-distance { font-size: 8px; }
.meta-icon { width: 28rpx; height: 28rpx; opacity: .8; }
.home-card-footer { display: flex; justify-content: space-between; align-items: center; }
.home-card-price-wrap { display: flex; align-items: baseline; gap: 4rpx; }
.home-card-price { font-size: 40rpx; font-weight: 700; color: #009966; }
.home-card-btn { padding: 18rpx 32rpx; background: #101828; color: #FFF; font-size: 28rpx; font-weight: 500; border-radius: 24rpx; }

/* 搜索浮层 */
.search-overlay { position: fixed; left: 0; right: 0; top: 0; bottom: 0; z-index: 200; }
.search-overlay-mask { position: absolute; left: 0; right: 0; top: 0; bottom: 0; background: rgba(0,0,0,.4); }
.search-overlay-content {
  position: absolute; left: 0; right: 0; top: 0;
  padding-top: env(safe-area-inset-top); background: #FFF; max-height: 80vh;
  display: flex; flex-direction: column;
}
.search-overlay-header {
  display: flex; align-items: center; gap: 24rpx;
  padding: 24rpx 32rpx; border-bottom: 1rpx solid #F3F4F6;
}
.search-overlay-input-wrap {
  flex: 1; display: flex; align-items: center; gap: 16rpx;
  padding: 20rpx 24rpx; background: #F9FAFB; border-radius: 24rpx;
}
.search-overlay-icon { width: 40rpx; height: 40rpx; opacity: .6; }
.search-overlay-input { flex: 1; font-size: 30rpx; }
.search-overlay-clear { font-size: 40rpx; color: #9CA3AF; padding: 0 8rpx; }
.search-overlay-cancel { font-size: 30rpx; color: #009966; font-weight: 500; }
.search-overlay-body { flex: 1; overflow-y: auto; padding: 24rpx 32rpx 48rpx; }
.search-empty { padding: 80rpx 0; text-align: center; font-size: 28rpx; color: #9CA3AF; }
.search-group { margin-bottom: 32rpx; }
.search-group-title { font-size: 24rpx; font-weight: 700; color: #6A7282; text-transform: uppercase; margin-bottom: 16rpx; display: block; }
.search-item { display: flex; align-items: center; gap: 24rpx; padding: 24rpx 0; border-bottom: 1rpx solid #F3F4F6; }
.search-item-img { width: 96rpx; height: 96rpx; border-radius: 16rpx; flex-shrink: 0; background: #E5E7EB; }
.search-item-info { flex: 1; min-width: 0; }
.search-item-name { font-size: 30rpx; font-weight: 600; color: #101828; display: block; }
.search-item-meta { font-size: 24rpx; color: #6A7282; display: block; margin-top: 4rpx; }
